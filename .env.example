# WakeBot Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# For maximum security, use the Windows Credential Manager instead:
#   python -m wakebot credentials set GEMINI_API_KEY your_key_here

# Google Gemini API Key (required only if vlm_provider is "gemini")
GEMINI_API_KEY=your_gemini_api_key_here
